generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserType {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  type        String
  license     String // JSON-encoded string[] (SQLite has no native array type)
  users       User[]
}

model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String // bcrypt hash
  name       String
  lastname   String
  gender     String
  email      String   @unique
  carnet     String
  adress     String
  phone      String
  typeId     Int
  type       UserType @relation(fields: [typeId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  eventsCreated    Event[]       @relation("EventCreatedBy")
  salesAsSeller    SaleProduct[] @relation("SaleProductSeller")
  salesAsClient    SaleProduct[] @relation("SaleProductClient")
  ticketSalesAsSeller SaleTicket[] @relation("SaleTicketSeller")
  ticketSalesAsClient SaleTicket[] @relation("SaleTicketClient")
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  img         String
  code        String   @unique
  type        String
  description String
  dateSale    DateTime
  dateOn      DateTime
  dateOff     DateTime
  startTime   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    Int
  createdBy User @relation("EventCreatedBy", fields: [userId], references: [id])

  mapId Int?
  map   Map? @relation(fields: [mapId], references: [id])

  tickets      Ticket[]
  products     Product[]
  saleProducts SaleProduct[]
  saleTickets  SaleTicket[]
}

model Map {
  id             Int      @id @default(autoincrement())
  name           String
  description    String
  img            String
  type           String
  x              Float
  y              Float
  radio          Float
  color          String
  size           Float
  backGround     String
  totalTables    Int      @default(0)
  totalTablesSeat Int     @default(0)
  totalSeats     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  areas  Area[]
  events Event[]
}

model Area {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  img         String
  icon        String
  type        String
  x           Float
  y           Float
  radio       Float
  color       String
  size        Float
  backGround  String
  totalTables Int      @default(0)
  totalSeats  Int      @default(0)
  totalCount  Int      @default(0)

  mapId Int
  map   Map @relation(fields: [mapId], references: [id])

  seats  Seat[]
  tables Table[]
}

model Table {
  id     Int    @id @default(autoincrement())
  name   String
  icon   String
  type   String
  x      Float
  y      Float
  radio  Float
  color  String
  size   Float

  areaId Int
  area   Area @relation(fields: [areaId], references: [id])

  seats Seat[]
}

model Seat {
  id     Int    @id @default(autoincrement())
  name   String
  icon   String
  type   String
  x      Float
  y      Float
  radio  Float
  color  String
  size   Float

  areaId Int
  area   Area @relation(fields: [areaId], references: [id])

  tableId Int?
  table   Table? @relation(fields: [tableId], references: [id])

  saleTickets SaleTicket[]
}

model Ticket {
  id          Int      @id @default(autoincrement())
  img         String
  code        String   @unique
  name        String
  description String
  type        String
  count       Int
  active      Boolean  @default(true)
  price       Float

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  saleTickets SaleTicket[]
}

model Product {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  img         String
  name        String
  description String
  type        String
  variant     String   @default("")
  count       Int
  active      Boolean  @default(true)
  price       Float

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  saleProducts SaleProduct[]
}

model SaleProduct {
  id          Int       @id @default(autoincrement())
  quantity    Int       @default(1)
  description String    @default("")
  dateSold    DateTime  @default(now())
  paidType    String
  codeQR      String    @unique
  deliveredAt DateTime?

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId Int
  seller User @relation("SaleProductSeller", fields: [userId], references: [id])

  clientId Int
  client   User @relation("SaleProductClient", fields: [clientId], references: [id])
}

model SaleTicket {
  id          Int       @id @default(autoincrement())
  status      Int       @default(1)
  active      Boolean   @default(true)
  description String
  dateSold    DateTime  @default(now())
  paidType    String
  codeQR      String    @unique
  checkedInAt DateTime?

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  seatId Int
  seat   Seat @relation(fields: [seatId], references: [id])

  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  userId Int
  seller User @relation("SaleTicketSeller", fields: [userId], references: [id])

  clientId Int
  client   User @relation("SaleTicketClient", fields: [clientId], references: [id])

  // Un mismo asiento no se puede vender dos veces para el mismo evento.
  @@unique([eventId, seatId])
}
