generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Un Tenant = un cliente (club/iglesia) instalado en esta misma app. Todo lo que un tenant crea
// (eventos, mapas, tickets, ventas, compradores...) queda acotado a su propio tenantId, así dos
// clientes comparten la misma base sin poder ver ni interferir con los datos del otro. La única
// cuenta sin tenant es el Super Admin (ver User.tenantId), que da de alta nuevos tenants.
model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  // GENERAL | CLUB | CHURCH — condiciona reglas de negocio propias de cada tipo de organización.
  // Por ahora solo CLUB tiene una: exigir carnet de socio o del socio que invita al reservar un
  // asiento (ver SaleTicket.attendeeType/sponsorCarnet y la validación en sale-tickets.ts/public.ts).
  type      String   @default("GENERAL")
  createdAt DateTime @default(now())

  users        User[]
  events       Event[]
  maps         Map[]
  areas        Area[]
  tables       Table[]
  seats        Seat[]
  tickets      Ticket[]
  products     Product[]
  saleTickets  SaleTicket[]
  saleProducts SaleProduct[]
  auditLogs    AuditLog[]
  appSettings  AppSetting[]
}

model UserType {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  type        String
  license     String // JSON-encoded string[] (SQLite has no native array type)
  users       User[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String // bcrypt hash
  name      String
  lastname  String
  gender    String
  email     String   @unique
  carnet    String
  adress    String
  phone     String
  typeId    Int
  type      UserType @relation(fields: [typeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Nullable SOLO para la cuenta de Super Admin, que opera fuera de todos los tenants (gestiona el
  // panel /tenants). Cualquier otro usuario (staff o comprador) siempre pertenece a un tenant.
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  eventsCreated       Event[]       @relation("EventCreatedBy")
  salesAsSeller       SaleProduct[] @relation("SaleProductSeller")
  salesAsClient       SaleProduct[] @relation("SaleProductClient")
  ticketSalesAsSeller SaleTicket[]  @relation("SaleTicketSeller")
  ticketSalesAsClient SaleTicket[]  @relation("SaleTicketClient")
  auditLogs           AuditLog[]    @relation("AuditLogUser")
}

// Registro de auditoría de acciones sensibles (alta/edición/borrado de Events, Products, Users,
// y borrado de ventas). userId es nullable y con SetNull para que el rastro sobreviva aunque el
// usuario que hizo la acción se borre después — perder el log sería peor que perder la referencia.
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)
  action    String // CREATE | UPDATE | DELETE
  entity    String // Event | Product | User | SaleTicket | SaleProduct
  entityId  Int
  summary   String
  createdAt DateTime @default(now())

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  img         String
  code        String   @unique
  type        String
  description String
  dateSale    DateTime
  dateOn      DateTime
  dateOff     DateTime
  startTime   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    Int
  createdBy User @relation("EventCreatedBy", fields: [userId], references: [id])

  mapId Int?
  map   Map? @relation(fields: [mapId], references: [id])

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  tickets      Ticket[]
  products     Product[]
  saleProducts SaleProduct[]
  saleTickets  SaleTicket[]
}

model Map {
  id              Int      @id @default(autoincrement())
  name            String
  description     String
  img             String
  type            String
  x               Float
  y               Float
  radio           Float
  color           String
  size            Float
  backGround      String
  totalTables     Int      @default(0)
  totalTablesSeat Int      @default(0)
  totalSeats      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  areas  Area[]
  events Event[]
}

model Area {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  img         String
  icon        String
  type        String
  x           Float
  y           Float
  radio       Float
  color       String
  size        Float
  backGround  String
  totalTables Int    @default(0)
  totalSeats  Int    @default(0)
  totalCount  Int    @default(0)

  mapId Int
  map   Map @relation(fields: [mapId], references: [id])

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  seats   Seat[]
  tables  Table[]
  tickets Ticket[]
}

model Table {
  id    Int    @id @default(autoincrement())
  name  String
  icon  String
  type  String
  x     Float
  y     Float
  radio Float
  color String
  size  Float

  areaId Int
  area   Area @relation(fields: [areaId], references: [id])

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  seats Seat[]
}

model Seat {
  id    Int    @id @default(autoincrement())
  name  String
  icon  String
  type  String
  x     Float
  y     Float
  radio Float
  color String
  size  Float

  areaId Int
  area   Area @relation(fields: [areaId], references: [id])

  tableId Int?
  table   Table? @relation(fields: [tableId], references: [id])

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  saleTickets SaleTicket[]
}

model Ticket {
  id          Int     @id @default(autoincrement())
  img         String
  code        String  @unique
  name        String
  description String
  type        String
  count       Int
  active      Boolean @default(true)
  price       Float

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  // Si se define, este tipo de ticket solo da acceso a asientos de esta área — el picker público
  // usa esto para no mostrarle al comprador áreas que su ticket no cubre (ej. tickets "General" vs
  // "VIP" ligados cada uno a su propia área). Sin asignar, el ticket sigue viendo todas las áreas
  // del mapa (comportamiento previo, retrocompatible).
  areaId Int?
  area   Area? @relation(fields: [areaId], references: [id])

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  saleTickets SaleTicket[]
}

model Product {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  img         String
  name        String
  description String
  type        String
  variant     String  @default("")
  count       Int
  active      Boolean @default(true)
  price       Float

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  saleProducts SaleProduct[]
}

model SaleProduct {
  id          Int       @id @default(autoincrement())
  quantity    Int       @default(1)
  description String    @default("")
  dateSold    DateTime  @default(now())
  paidType    String
  codeQR      String    @unique
  deliveredAt DateTime?

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId Int
  seller User @relation("SaleProductSeller", fields: [userId], references: [id])

  clientId Int
  client   User @relation("SaleProductClient", fields: [clientId], references: [id])

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model SaleTicket {
  id          Int       @id @default(autoincrement())
  status      Int       @default(1)
  active      Boolean   @default(true)
  description String
  dateSold    DateTime  @default(now())
  paidType    String
  codeQR      String    @unique
  checkedInAt DateTime?

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  seatId Int
  seat   Seat @relation(fields: [seatId], references: [id])

  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  userId Int
  seller User @relation("SaleTicketSeller", fields: [userId], references: [id])

  clientId Int
  client   User @relation("SaleTicketClient", fields: [clientId], references: [id])

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Solo tienen sentido en tenants tipo CLUB (ver Tenant.type) — SOCIO | INVITADO. Un invitado no
  // es socio del club: en vez de su propio carnet, se guarda el carnet del socio que lo invitó
  // (sponsorCarnet), y se limita a 2 invitados por socio por evento (validado en la ruta, no acá).
  attendeeType  String  @default("SOCIO")
  sponsorCarnet String?

  // Un mismo asiento no se puede vender dos veces para el mismo evento.
  @@unique([eventId, seatId])
}

// Configuración general de la app (ej. color de acento) — key-value genérico en vez de una
// columna por setting, para no necesitar una migración cada vez que se agrega una opción nueva.
// PK compuesta (tenantId, key): cada cliente configura la suya propia sin pisar la de otro.
model AppSetting {
  key   String
  value String

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@id([tenantId, key])
}
